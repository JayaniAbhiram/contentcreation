# --- Production Environment Variables ---

# 1. Supabase (Copy from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (Backend/Worker Only)

# 2. API URLs (Update after deployment)
NEXT_PUBLIC_BACKEND_URL=https://your-api.onrender.com

# 3. AI Keys
GEMINI_API_KEY=your-gemini-key

# 4. Telegram (Review Bot)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id (Owner)

# 5. YouTube OAuth
YOUTUBE_CLIENT_ID=your-google-client-id
YOUTUBE_CLIENT_SECRET=your-google-client-secret
YOUTUBE_REDIRECT_URI=https://your-api.onrender.com/auth/youtube/callback

# 6. Meta / Instagram OAuth
META_CLIENT_ID=your-fb-app-id
META_CLIENT_SECRET=your-fb-app-secret
META_REDIRECT_URI=https://your-api.onrender.com/auth/instagram/callback

# 7. Worker Configuration
ENV=production
TEMP_DIR=/tmp/articlo-render (Ensure this is writable)
